[gd_scene load_steps=3 format=3 uid="uid://d1pauseoverlay"]

[ext_resource type="Script" path="res://scripts/ui/pause_overlay.gd" id="1_pause"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
bg_color = Color(0.05, 0.07, 0.12, 0.88)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
